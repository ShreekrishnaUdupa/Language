Terminals unused in grammar

    "."
    UNKNOWN
    STRING_LITERAL


Grammar

    0 $accept: program $end

    1 program: classes mainClass classes

    2 mainClass: "class" "Main" "{" "void" "main" "(" ")" "{" statements "}" "}" optionalSemicolons

    3 classes: classes classDef
    4        | %empty

    5 classDef: "class" IDENTIFIER "{" functions "}" optionalSemicolons

    6 optionalSemicolons: optionalSemicolons ";"
    7                   | %empty

    8 accessSpecifiers: "public" ':'
    9                 | "private" ':'
   10                 | "protected" ':'
   11                 | %empty

   12 functions: functions accessSpecifiers function
   13          | %empty

   14 function: IDENTIFIER IDENTIFIER "(" arguments ")" "{" statements "}"

   15 arguments: argumentList
   16          | %empty

   17 argumentList: IDENTIFIER IDENTIFIER
   18             | argumentList "," IDENTIFIER IDENTIFIER

   19 statements: statements statement
   20           | %empty

   21 statement: declaration
   22          | expression ";"
   23          | "return" expression ";"
   24          | "return" ";"
   25          | ";"

   26 declaration: IDENTIFIER IDENTIFIER init moreDeclarations ";"

   27 init: "=" expression
   28     | %empty

   29 moreDeclarations: moreDeclarations "," IDENTIFIER init
   30                 | %empty

   31 expression: expression "+" expression
   32           | expression "-" expression
   33           | expression "*" expression
   34           | expression "/" expression
   35           | expression "%" expression
   36           | expression "|" expression
   37           | expression "&" expression
   38           | expression ">" expression
   39           | expression "<" expression
   40           | expression "^" expression
   41           | expression "<<" expression
   42           | expression ">>" expression
   43           | expression "||" expression
   44           | expression "&&" expression
   45           | expression ">=" expression
   46           | expression "<=" expression
   47           | expression "==" expression
   48           | expression "!=" expression
   49           | "+" expression
   50           | "-" expression
   51           | "!" expression
   52           | "~" expression
   53           | "*" IDENTIFIER
   54           | "&" IDENTIFIER
   55           | "++" IDENTIFIER
   56           | "--" IDENTIFIER
   57           | IDENTIFIER "++"
   58           | IDENTIFIER "--"
   59           | IDENTIFIER "=" expression
   60           | IDENTIFIER "+=" expression
   61           | IDENTIFIER "-=" expression
   62           | IDENTIFIER "*=" expression
   63           | IDENTIFIER "/=" expression
   64           | IDENTIFIER "%=" expression
   65           | IDENTIFIER "&=" expression
   66           | IDENTIFIER "|=" expression
   67           | IDENTIFIER "^=" expression
   68           | IDENTIFIER "<<=" expression
   69           | IDENTIFIER ">>=" expression
   70           | "(" expression ")"
   71           | IDENTIFIER
   72           | INTEGER_LITERAL
   73           | FLOATING_LITERAL


