Terminals unused in grammar

    "."
    UNKNOWN


Grammar

    0 $accept: program $end

    1 program: classes

    2 classes: classes classDef
    3        | %empty

    4 classDef: "class" IDENTIFIER "{" functions "}" optionalSemicolons

    5 optionalSemicolons: optionalSemicolons ";"
    6                   | %empty

    7 accessSpecifiers: "public" ":"
    8                 | "private" ":"
    9                 | "protected" ":"
   10                 | %empty

   11 functions: functions accessSpecifiers function optionalSemicolons
   12          | %empty

   13 function: IDENTIFIER IDENTIFIER "(" parameters ")" "{" statements "}"
   14         | constructorDef
   15         | destructorDef

   16 parameters: parametersList
   17           | %empty

   18 parametersList: IDENTIFIER IDENTIFIER
   19               | parametersList "," IDENTIFIER IDENTIFIER

   20 constructorDef: "constructor" "(" parameters ")" "{" statements "}"

   21 destructorDef: "destructor" "(" ")" "{" statements "}"

   22 variableDeclarations: IDENTIFIER IDENTIFIER init moreVariableDeclarations ";"

   23 init: "=" expression
   24     | %empty

   25 moreVariableDeclarations: moreVariableDeclarations "," IDENTIFIER init
   26                         | %empty

   27 functionCall: IDENTIFIER "(" arguments ")"

   28 arguments: argumentsList
   29          | %empty

   30 argumentsList: argumentsList "," expression
   31              | expression

   32 ifStatement: "if" "(" expression ")" "{" statements "}"

   33 ifElseStatement: ifStatement elseIfStatement elseStatement

   34 elseIfStatement: elseIfStatement "else" ifStatement
   35                | %empty

   36 elseStatement: "else" "(" expression ")" "{" statements "}"

   37 statements: statements statement
   38           | %empty

   39 statement: variableDeclarations
   40          | ifStatement
   41          | ifElseStatement
   42          | expression ";"
   43          | "return" expression ";"
   44          | "return" ";"
   45          | ";"

   46 expression: expression "+" expression
   47           | expression "-" expression
   48           | expression "*" expression
   49           | expression "/" expression
   50           | expression "%" expression
   51           | expression "|" expression
   52           | expression "&" expression
   53           | expression ">" expression
   54           | expression "<" expression
   55           | expression "^" expression
   56           | expression "<<" expression
   57           | expression ">>" expression
   58           | expression "||" expression
   59           | expression "&&" expression
   60           | expression ">=" expression
   61           | expression "<=" expression
   62           | expression "==" expression
   63           | expression "!=" expression
   64           | IDENTIFIER "=" expression
   65           | IDENTIFIER "+=" expression
   66           | IDENTIFIER "-=" expression
   67           | IDENTIFIER "*=" expression
   68           | IDENTIFIER "/=" expression
   69           | IDENTIFIER "%=" expression
   70           | IDENTIFIER "&=" expression
   71           | IDENTIFIER "|=" expression
   72           | IDENTIFIER "^=" expression
   73           | IDENTIFIER "<<=" expression
   74           | IDENTIFIER ">>=" expression
   75           | "+" expression
   76           | "-" expression
   77           | "!" expression
   78           | "~" expression
   79           | "*" IDENTIFIER
   80           | "&" IDENTIFIER
   81           | "++" IDENTIFIER
   82           | "--" IDENTIFIER
   83           | IDENTIFIER "++"
   84           | IDENTIFIER "--"
   85           | "(" expression ")"
   86           | functionCall
   87           | IDENTIFIER
   88           | INTEGER_LITERAL
   89           | FLOATING_LITERAL
   90           | BOOLEAN_LITERAL
   91           | STRING_LITERAL


